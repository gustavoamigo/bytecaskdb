{
  "name": "codespaces-blank",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash"
          }
        }
      },
      "extensions": [
        "ms-vscode.cmake-tools", 
        
        "tboox.xmake-vscode"
      ]
    }
  },
  "remoteUser": "gustavoamigo",
  "postCreateCommand": "xmake --version"
}
